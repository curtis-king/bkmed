# ============================================
# MedConnect Backend - Variables d'environnement
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs

# --- Serveur ---
PORT=5000
NODE_ENV=production
FRONTEND_URL=http://localhost:3000

# --- Base de données MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=medconnect
DB_USER=root
DB_PASSWORD=votre_mot_de_passe

# --- JWT ---
JWT_SECRET=votre_jwt_secret_ici

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_app
SMTP_FROM="MedConnect <noreply@medconnect.com>"

# --- MTN Mobile Money ---
MOBILE_MONEY_SIMULATION=true
REGISTRATION_FEE=5000
MTN_MOMO_API_URL=https://proxy.momoapi.mtn.com
MTN_MOMO_API_KEY=
MTN_MOMO_API_SECRET=
MTN_MOMO_PRIMARY_KEY=
MTN_MOMO_COLLECTION_PHONE=
MTN_MOMO_ENVIRONMENT=sandbox

# --- Airtel Money ---
AIRTEL_MONEY_API_URL=https://openapi.airtel.africa
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=
AIRTEL_MONEY_ENVIRONMENT=sandbox
